// Це часто трапляється при роботі з масивами, що створюються динамічно. Наприклад, створення списку всіх пар елементів:
function generatePairs(items) {
    const pairs = [];

    for (let i = 0; i < items.length; i++) {
        for (let j = i + 1; j < items.length; j++) {
            pairs.push([items[i], items[j]]);
        }
    }

    return pairs;
}

// Приклад використання
const items = [1, 2, 3, 4];
console.log(generatePairs(items));//[(1, 2), (1, 3), (1, 4), (2, 3), (2, 4), (3, 4)]
